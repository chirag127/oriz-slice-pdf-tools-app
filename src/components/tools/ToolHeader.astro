---
/*
 * ToolHeader — the column→workbench transition entry.
 *
 * Renders the breadcrumb + tool title + two-paragraph description in the
 * 78ch reading column, then a § page-break. The actual workbench (file
 * dropzone, page thumbnails, "Bind document" CTA) is the tool React
 * island that follows in the page.
 *
 * Voice cue: tools are "implements" with a verb name like "bind" not
 * "merge PDF". Title still uses the human name from data/tools.ts.
 */

interface Props {
  toolName: string
  toolSlug: string
  category: string
  description: string
  /** Section number that the leading § page-break renders. */
  section?: string
}

const { toolName, toolSlug, description, section = 'i' } = Astro.props

// Map data-categories onto the four column labels from the home TOC.
const COL_LABEL: Record<string, string> = {
  organize: 'organise',
  optimize: 'organise',
  edit: 'organise',
  'convert-to-pdf': 'convert',
  'convert-from-pdf': 'convert',
  security: 'secure',
  ai: 'read',
}
const colLabel = COL_LABEL[Astro.props.category] ?? 'tools'
---

<section class="th-column">
  <p class="th-eyebrow smallcaps">
    <a href="/">tools</a>
    <span aria-hidden="true">/</span>
    <a href={`/#${colLabel}`}>{colLabel}</a>
    <span aria-hidden="true">/</span>
    <span>{toolName.toLowerCase()}</span>
  </p>

  <h1 class="th-title">{toolName}</h1>

  <p class="th-lede">
    {description}
  </p>

  <p class="th-promise">
    Files stay on this device. The PDF you load is processed in your browser
    using <code>pdf-lib</code> and friends, then saved back to disk — no upload,
    no server, no copy kept.
  </p>
</section>

<hr data-section={section} />

<style>
  .th-column {
    max-width: var(--container-prose);
    margin-inline: auto;
    padding: 3rem clamp(1.25rem, 4vw, 2rem) 1rem;
  }
  .th-eyebrow {
    margin: 0 0 1.25rem;
    color: var(--margin);
    font-size: 13px;
    letter-spacing: 0.08em;
  }
  .th-eyebrow a { color: var(--margin); }
  .th-eyebrow a:hover { color: var(--ledger); }
  .th-eyebrow span[aria-hidden] { margin-inline: 0.4em; color: var(--rule); }

  .th-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.875rem, 4.5vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 1rem;
  }

  .th-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1875rem;
    color: var(--margin);
    line-height: 1.5;
    margin: 0 0 1rem;
    max-width: 56ch;
  }

  .th-promise {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink);
    margin: 0;
    max-width: 65ch;
  }
  .th-promise code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    padding: 0 0.25em;
    background: var(--paper-2);
    border: 1px solid var(--rule);
  }
</style>
