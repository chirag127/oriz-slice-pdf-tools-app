---
/*
 * Footer — colophon. Opens with the running-foot rule + centered domain bug
 * `─── pdf-tools.oriz.in ───`. Three small-caps Source Serif columns:
 * COLOPHON / LINKS / FAMILY. Final line is privacy reassurance set in
 * small-caps separated by middle dots — the ONLY middle dots on the site.
 *
 * No newsletter signup, no social icon strip, no emoji. Pure printed-page
 * attribution.
 */
import { FAMILY, FAMILY_SITES } from '~/lib/family'

const year = new Date().getFullYear()
const familyOthers = FAMILY_SITES.filter((s) => s.slug !== 'pdf-tools').slice(0, 6)

const deployTime =
  import.meta.env.PUBLIC_DEPLOY_TIME ?? new Date().toISOString().slice(0, 10)
const gitSha = import.meta.env.PUBLIC_GIT_SHA ?? 'dev'
---

<footer class="ft">
  <div class="ft-foot" aria-hidden="false">
    <span class="ft-foot-rule"></span>
    <span class="ft-foot-domain">pdf-tools.oriz.in</span>
  </div>

  <div class="ft-cols">
    <section class="ft-col">
      <h2 class="ft-h">colophon</h2>
      <p>set in <em>GT Sectra</em></p>
      <p>&amp; <em>Source Serif 4</em></p>
      <p>processing on-device only</p>
      <p>MIT licence</p>
    </section>

    <section class="ft-col">
      <h2 class="ft-h">links</h2>
      <ul>
        <li><a href={`https://github.com/${FAMILY.operator.githubHandle}/oriz-pdf-tools`}>github</a></li>
        <li><a href="/blog/">blog</a></li>
        <li><a href="/about/">about</a></li>
        <li><a href="/contact/">contact</a></li>
        <li><a href="/legal/">legal</a></li>
      </ul>
    </section>

    <section class="ft-col">
      <h2 class="ft-h">family</h2>
      <ul>
        {familyOthers.map((s) => (
          <li><a href={s.url}>{s.slug.replace('-tools', '')}</a></li>
        ))}
        <li><a href={FAMILY.rootOrigin}>see all →</a></li>
      </ul>
    </section>
  </div>

  <p class="ft-attribution">
    <span>© {year} {FAMILY.operator.name}</span>
    <span aria-hidden="true">·</span>
    <span>MIT</span>
    <span aria-hidden="true">·</span>
    <span>all processing on-device</span>
  </p>

  <p class="ft-meta mono">
    <time datetime={deployTime}>{deployTime}</time>
    <span aria-hidden="true">·</span>
    <span>commit {gitSha}</span>
  </p>
</footer>

<style>
  .ft {
    margin-top: 5rem;
    padding: 3rem clamp(1rem, 4vw, 2rem) 2rem;
    max-width: var(--container-page);
    margin-inline: auto;
    color: var(--ink);
  }

  /* Running-foot — domain bug centered on a 1px ledger rule. */
  .ft-foot {
    position: relative;
    text-align: center;
    margin-bottom: 3rem;
    height: 1.5em;
  }
  .ft-foot-rule {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 1px;
    background: var(--rule);
    transform: translateY(-50%);
  }
  .ft-foot-domain {
    position: relative;
    background: var(--paper);
    padding-inline: 1rem;
    color: var(--margin);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.16em;
  }

  .ft-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }
  @media (min-width: 640px) {
    .ft-cols { grid-template-columns: repeat(3, 1fr); gap: 3rem; }
  }

  .ft-col p,
  .ft-col li {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--ink);
    margin: 0 0 0.5rem;
    line-height: 1.6;
  }
  .ft-col em { color: var(--margin); }
  .ft-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .ft-col a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
  }
  .ft-col a:hover {
    color: var(--ledger);
    text-decoration-color: var(--ledger);
  }
  .ft-h {
    font-family: var(--font-serif);
    font-size: 13px;
    font-feature-settings: 'smcp' 1;
    letter-spacing: 0.12em;
    color: var(--margin);
    font-weight: 500;
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
  }

  .ft-attribution {
    text-align: center;
    margin: 0 0 0.75rem;
    color: var(--margin);
    font-family: var(--font-serif);
    font-size: 13px;
    font-feature-settings: 'smcp' 1;
    letter-spacing: 0.06em;
  }
  .ft-attribution span[aria-hidden] {
    margin-inline: 0.5rem;
    color: var(--rule);
  }

  .ft-meta {
    text-align: center;
    margin: 0;
    color: var(--margin);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
  }
  .ft-meta span[aria-hidden] {
    margin-inline: 0.5rem;
    color: var(--rule);
  }
</style>
