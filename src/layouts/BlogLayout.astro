---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  date: string;
  category?: string;
  image?: string;
  author?: string;
  readingTime?: string;
}

const {
  title,
  description,
  date,
  category = "PDF Tips",
  author = "Chirag Singhal",
  readingTime = "5 min read",
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const canonical = Astro.url.pathname;
---

<BaseLayout
  title={`${title} — oriz / pdf-tools blog`}
  description={description}
  canonical={canonical}
  pageNum="iii"
>
  <article class="blog-column">
    <p class="blog-eyebrow smallcaps">
      <a href="/">tools</a>
      <span aria-hidden="true">/</span>
      <a href="/blog/">blog</a>
      <span aria-hidden="true">/</span>
      <span>{category.toLowerCase()}</span>
    </p>

    <h1 class="blog-h">{title}</h1>

    <p class="blog-lede">{description}</p>

    <p class="blog-meta mono">
      <time datetime={date}>{formattedDate}</time>
      <span aria-hidden="true">·</span>
      <span>{readingTime}</span>
      <span aria-hidden="true">·</span>
      <span>by {author}</span>
    </p>

    <hr data-section="i" />

    <div class="blog-body">
      <slot />
    </div>

    <hr data-section="ii" />

    <footer class="blog-foot">
      <a href="/blog/" class="blog-back">← all writing</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .blog-column {
    max-width: var(--container-blog);
    margin-inline: auto;
    padding: 3rem clamp(1.25rem, 4vw, 2rem) 0;
    /* 8ch left gutter for marginalia. */
    padding-left: clamp(1.25rem, 8ch, 4rem);
  }

  .blog-eyebrow {
    margin: 0 0 1rem;
    color: var(--margin);
    font-size: 13px;
    letter-spacing: 0.08em;
  }
  .blog-eyebrow a { color: var(--margin); }
  .blog-eyebrow a:hover { color: var(--ledger); }
  .blog-eyebrow span[aria-hidden] { margin-inline: 0.4em; color: var(--rule); }

  .blog-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 1rem;
  }
  .blog-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1875rem;
    color: var(--margin);
    line-height: 1.5;
    margin: 0 0 1rem;
    max-width: 56ch;
  }
  .blog-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--margin);
    letter-spacing: 0.06em;
    margin: 0;
  }
  .blog-meta span[aria-hidden] {
    margin-inline: 0.5rem;
    color: var(--rule);
  }

  .blog-body {
    padding-block: 1rem 2rem;
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.6875;
    color: var(--ink);
  }

  /* Drop cap on the first paragraph — GT Sectra 64px, 3 lines tall, ledger. */
  .blog-body :global(> p:first-of-type::first-letter),
  .blog-body :global(p.dropcap::first-letter) {
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 500;
    color: var(--ledger);
    float: left;
    line-height: 0.9;
    padding: 0.25rem 0.5rem 0 0;
  }

  .blog-body :global(h2) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.5rem;
    letter-spacing: -0.005em;
    color: var(--ink);
    margin: 2.5rem 0 1rem;
  }
  .blog-body :global(h3) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.25rem;
    color: var(--ink);
    margin: 1.75rem 0 0.625rem;
  }
  .blog-body :global(p) { margin: 0 0 1.25rem; }
  .blog-body :global(a) {
    color: var(--ledger);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--ledger) 40%, transparent);
    text-underline-offset: 3px;
  }
  .blog-body :global(a:hover) { text-decoration-color: var(--ledger); }
  .blog-body :global(strong) { color: var(--ink); font-weight: 600; }

  /* Marginalia: ordered-list numbers float into the left gutter. */
  .blog-body :global(ol) {
    list-style: none;
    counter-reset: ml;
    padding-left: 0;
    margin: 0 0 1.25rem;
  }
  .blog-body :global(ol > li) {
    counter-increment: ml;
    position: relative;
    padding-left: 4ch;
    margin-bottom: 0.5rem;
  }
  .blog-body :global(ol > li::before) {
    content: counter(ml, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0.125em;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--margin);
    letter-spacing: 0.06em;
  }

  .blog-body :global(ul) {
    list-style: none;
    padding-left: 0;
  }
  .blog-body :global(ul > li) {
    position: relative;
    padding-left: 1.5ch;
    margin-bottom: 0.5rem;
  }
  .blog-body :global(ul > li::before) {
    content: "·";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--margin);
  }

  /* Pull-quote — vermilion left rule, italic Source Serif 18/30, no marks. */
  .blog-body :global(blockquote) {
    border-left: 3px solid var(--vermilion);
    padding: 0.25rem 0 0.25rem 1.25rem;
    margin: 1.5rem 0;
    color: var(--ink);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.125rem;
    line-height: 1.6;
  }
  .blog-body :global(blockquote p) { margin: 0; }

  /* Code — JetBrains Mono on a #EBE3D2 tint, 1px rule left border only. */
  .blog-body :global(pre) {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.55;
    background: var(--paper-2);
    border-left: 1px solid var(--rule);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }
  .blog-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    padding: 0 0.25em;
    background: var(--paper-2);
    border: 1px solid var(--rule);
  }
  .blog-body :global(pre code) {
    background: transparent;
    border: 0;
    padding: 0;
  }

  /* Footnote refs (sup) and footnotes section at foot above 1px rule. */
  .blog-body :global(sup),
  .blog-body :global(.footnote-ref) {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--margin);
    margin-left: 0.125em;
  }
  .blog-body :global(.footnotes),
  .blog-body :global(section.footnotes) {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--rule);
    font-size: 14px;
    line-height: 1.55;
    color: var(--margin);
  }
  .blog-body :global(.footnotes ol) {
    counter-reset: fn;
  }

  .blog-foot {
    padding-block: 1rem 2rem;
  }
  .blog-back {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--margin);
    font-size: 14px;
  }
  .blog-back:hover { color: var(--ledger); }
</style>
