---
import ToolLayout from "~/layouts/ToolLayout.astro";
import { TOOL_FAQS } from "~/data/tool-faqs";
import { TOOL_PROSE } from "~/data/tool-prose";

const slug = "optimize-pdf";
const title = "Optimize PDF Online — Free & No Upload";
const description = "Clean metadata and optimize PDF structure. Remove unnecessary data for smaller, cleaner files. Free, private, browser-based.";
const faqs = TOOL_FAQS[slug] ?? [];
const proseHTML = TOOL_PROSE[slug] ?? "";
---

<ToolLayout slug={slug} title={title} description={description} faqs={faqs}>
	<Fragment set:html={proseHTML} />
</ToolLayout>

<script>
	import { createElement } from "react";
	import { createRoot } from "react-dom/client";
	import OptimizePDF from "../../tools/OptimizePDF";
	const m = document.getElementById("tool-mount");
	if (m) createRoot(m).render(createElement(OptimizePDF));
</script>
