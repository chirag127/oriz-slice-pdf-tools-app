---
import ToolLayout from "~/layouts/ToolLayout.astro";
import { TOOL_FAQS } from "~/data/tool-faqs";
import { TOOL_PROSE } from "~/data/tool-prose";

const slug = "extract-pages";
const title = "Extract Pages from PDF — Free & No Upload";
const description = "Extract specific pages from PDF into a new file. Select page range to export. Free, private, browser-based.";
const faqs = TOOL_FAQS[slug] ?? [];
const proseHTML = TOOL_PROSE[slug] ?? "";
---

<ToolLayout slug={slug} title={title} description={description} faqs={faqs}>
	<Fragment set:html={proseHTML} />
</ToolLayout>

<script>
	import { createElement } from "react";
	import { createRoot } from "react-dom/client";
	import ExtractPages from "../../tools/ExtractPages";
	const m = document.getElementById("tool-mount");
	if (m) createRoot(m).render(createElement(ExtractPages));
</script>
