---
import ToolLayout from "~/layouts/ToolLayout.astro";
import { TOOL_FAQS } from "~/data/tool-faqs";
import { TOOL_PROSE } from "~/data/tool-prose";

const slug = "protect-pdf";
const title = "Protect PDF with Password — Free & No Upload";
const description = "Add password protection to your PDF. Set user/owner passwords and permissions. Free, private, browser-based.";
const faqs = TOOL_FAQS[slug] ?? [];
const proseHTML = TOOL_PROSE[slug] ?? "";
---

<ToolLayout slug={slug} title={title} description={description} faqs={faqs}>
	<Fragment set:html={proseHTML} />
</ToolLayout>

<script>
	import { createElement } from "react";
	import { createRoot } from "react-dom/client";
	import ProtectPDF from "../../tools/ProtectPDF";
	const m = document.getElementById("tool-mount");
	if (m) createRoot(m).render(createElement(ProtectPDF));
</script>
