---
import ToolLayout from "~/layouts/ToolLayout.astro";
import { TOOL_FAQS } from "~/data/tool-faqs";
import { TOOL_PROSE } from "~/data/tool-prose";

const slug = "remove-pages";
const title = "Remove Pages from PDF — Free & No Upload";
const description = "Delete unwanted pages from PDF files. Select specific pages to remove. Free, private, browser-based.";
const faqs = TOOL_FAQS[slug] ?? [];
const proseHTML = TOOL_PROSE[slug] ?? "";
---

<ToolLayout slug={slug} title={title} description={description} faqs={faqs}>
	<Fragment set:html={proseHTML} />
</ToolLayout>

<script>
	import { createElement } from "react";
	import { createRoot } from "react-dom/client";
	import RemovePages from "../../tools/RemovePages";
	const m = document.getElementById("tool-mount");
	if (m) createRoot(m).render(createElement(RemovePages));
</script>
