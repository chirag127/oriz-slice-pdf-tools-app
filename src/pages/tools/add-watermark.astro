---
import ToolLayout from "~/layouts/ToolLayout.astro";
import { TOOL_FAQS } from "~/data/tool-faqs";
import { TOOL_PROSE } from "~/data/tool-prose";

const slug = "add-watermark";
const title = "Add Watermark to PDF — Free & No Upload";
const description = "Stamp text watermarks on PDF pages. Customize text, size, opacity, and rotation. Free, private, browser-based.";
const faqs = TOOL_FAQS[slug] ?? [];
const proseHTML = TOOL_PROSE[slug] ?? "";
---

<ToolLayout slug={slug} title={title} description={description} faqs={faqs}>
	<Fragment set:html={proseHTML} />
</ToolLayout>

<script>
	import { createElement } from "react";
	import { createRoot } from "react-dom/client";
	import AddWatermark from "../../tools/AddWatermark";
	const m = document.getElementById("tool-mount");
	if (m) createRoot(m).render(createElement(AddWatermark));
</script>
