---
import ToolLayout from "~/layouts/ToolLayout.astro";
import { TOOL_FAQS } from "~/data/tool-faqs";
import { TOOL_PROSE } from "~/data/tool-prose";

const slug = "pdf-to-jpg";
const title = "PDF to JPG Online — Free & No Upload";
const description = "Convert PDF pages to high-quality JPG images. Each page is saved as a separate image file. Free, private, browser-based.";
const faqs = TOOL_FAQS[slug] ?? [];
const proseHTML = TOOL_PROSE[slug] ?? "";
---

<ToolLayout slug={slug} title={title} description={description} faqs={faqs}>
	<Fragment set:html={proseHTML} />
</ToolLayout>

<script>
	import { createElement } from "react";
	import { createRoot } from "react-dom/client";
	import PDFtoJPG from "../../tools/PDFtoJPG";
	const m = document.getElementById("tool-mount");
	if (m) createRoot(m).render(createElement(PDFtoJPG));
</script>
