---
import ToolLayout from "~/layouts/ToolLayout.astro";
import { TOOL_FAQS } from "~/data/tool-faqs";
import { TOOL_PROSE } from "~/data/tool-prose";

const slug = "ai-summarizer";
const title = "AI PDF Summarizer — Free & No Upload";
const description = "AI-powered PDF analysis and summarization using advanced AI. Extract key insights from any PDF. Free, private.";
const faqs = TOOL_FAQS[slug] ?? [];
const proseHTML = TOOL_PROSE[slug] ?? "";
---

<ToolLayout slug={slug} title={title} description={description} faqs={faqs}>
	<Fragment set:html={proseHTML} />
</ToolLayout>

<script>
	import { createElement } from "react";
	import { createRoot } from "react-dom/client";
	import AISummarizer from "../../tools/AISummarizer";
	const m = document.getElementById("tool-mount");
	if (m) createRoot(m).render(createElement(AISummarizer));
</script>
