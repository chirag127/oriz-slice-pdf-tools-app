---
import ToolLayout from "~/layouts/ToolLayout.astro";
import { TOOL_FAQS } from "~/data/tool-faqs";
import { TOOL_PROSE } from "~/data/tool-prose";

const slug = "repair-pdf";
const title = "Repair PDF Online — Free & No Upload";
const description = "Fix corrupted or damaged PDF files. Attempt to recover and repair broken PDFs. Free, private, browser-based.";
const faqs = TOOL_FAQS[slug] ?? [];
const proseHTML = TOOL_PROSE[slug] ?? "";
---

<ToolLayout slug={slug} title={title} description={description} faqs={faqs}>
	<Fragment set:html={proseHTML} />
</ToolLayout>

<script>
	import { createElement } from "react";
	import { createRoot } from "react-dom/client";
	import RepairPDF from "../../tools/RepairPDF";
	const m = document.getElementById("tool-mount");
	if (m) createRoot(m).render(createElement(RepairPDF));
</script>
