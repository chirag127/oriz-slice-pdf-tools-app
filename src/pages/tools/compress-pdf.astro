---
import ToolLayout from "~/layouts/ToolLayout.astro";
import { TOOL_FAQS } from "~/data/tool-faqs";
import { TOOL_PROSE } from "~/data/tool-prose";

const slug = "compress-pdf";
const title = "Compress PDF Online — Free & No Upload";
const description = "Reduce PDF file size while preserving quality. Choose from three compression levels. Free, private, browser-based processing.";
const faqs = TOOL_FAQS[slug] ?? [];
const proseHTML = TOOL_PROSE[slug] ?? "";
---

<ToolLayout slug={slug} title={title} description={description} faqs={faqs}>
	<Fragment set:html={proseHTML} />
</ToolLayout>

<script>
	import { createElement } from "react";
	import { createRoot } from "react-dom/client";
	import CompressPDF from "../../tools/CompressPDF";
	const m = document.getElementById("tool-mount");
	if (m) createRoot(m).render(createElement(CompressPDF));
</script>
