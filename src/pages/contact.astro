---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { ContactForm } from '@chirag127/oriz-ui'
import { FAMILY } from '~/lib/family'
---

<BaseLayout
  title="contact — oriz / pdf-tools"
  description="Get in touch about pdf.oriz.in — bug reports, feature requests, partnerships."
  pageNum="ii"
>
  <div class="page-head">
    <p class="eyebrow"><a href="/">tools</a> / contact</p>
    <h1>Contact.</h1>
    <p class="lede">
      Bug, idea, or an implement you wish existed? Email is fastest:
      <a href={`mailto:${FAMILY.operator.email}`}><strong>{FAMILY.operator.email}</strong></a>.
    </p>
  </div>

  <hr data-section="i" />

  <section class="prose">
    <p>
      Since every tool runs entirely in your browser, I can't see your files
      or recover them — but I can fix bugs, ship missing implements, and
      answer anything else. The form below posts to Web3Forms which forwards
      to my inbox; nothing about the message is stored on this site.
    </p>

    <ContactForm
      client:load
      web3formsKey={import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''}
      fromName="pdf.oriz.in contact form"
    />

    <p class="meta">
      For privacy questions or DMCA notices, see the
      <a href="/legal/grievance/">grievance officer</a> page (mandatory under
      IT Rules 2021).
    </p>
  </section>
</BaseLayout>
