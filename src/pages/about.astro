---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { FAMILY } from '~/lib/family'
import { SITE_CONFIG } from '~/lib/siteConfig'
---

<BaseLayout
  title={`about — ${SITE_CONFIG.name}`}
  description={`About ${SITE_CONFIG.name}: free, on-device PDF tools — part of the ${FAMILY.brand} family by ${FAMILY.operator.name}.`}
  pageNum="ii"
>
  <div class="page-head">
    <p class="eyebrow"><a href="/">tools</a> / about</p>
    <h1>About this desk.</h1>
    <p class="lede">
      A typesetter's bench for documents — twenty-three implements that never
      see your file. Built and maintained in Bhubaneswar.
    </p>
  </div>

  <hr data-section="i" />

  <article class="prose">
    <p>
      <strong>oriz / pdf-tools</strong> is a free, browser-based set of PDF
      implements. Twenty-three tools to bind, split, compress, convert,
      redact, sign, and OCR — all running on your device.
    </p>

    <h2>What stays on-device</h2>
    <p>
      Every implement here runs entirely in your browser using
      <code>pdf-lib</code>, <code>pdfjs-dist</code>,
      <code>tesseract.js</code>, and a small set of friends. There is no
      upload, no server-side processing, and no copy of your file kept on the
      site. Sign-in is optional and only stores cross-site preferences — it
      never sees your PDFs.
    </p>

    <h2>The family</h2>
    <p>
      pdf-tools is one of eleven sites under the
      <a href={FAMILY.rootOrigin}>{FAMILY.brand}</a> umbrella — a small set
      of free, fast, quiet sites built by
      <a href={`${FAMILY.rootOrigin}/about/`}>{FAMILY.operator.name}</a>.
      They share a sign-in, a design system, and a single principle: useful,
      free, no surveillance.
    </p>

    <h2>Open source</h2>
    <p>
      The site is open source under MIT at
      <a href={`https://github.com/${FAMILY.operator.githubHandle}/oriz-pdf-tools`}>
        github.com/{FAMILY.operator.githubHandle}/oriz-pdf-tools
      </a>. Issues, PRs, and tool requests welcome.
    </p>

    <h2>Contact</h2>
    <p>
      Email: <a href={`mailto:${FAMILY.operator.email}`}>{FAMILY.operator.email}</a>.
      Or use the <a href="/contact/">contact form</a>.
    </p>
  </article>
</BaseLayout>
