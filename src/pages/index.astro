---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { tools, categories } from '~/data/tools'
import { SITE_CONFIG } from '~/lib/siteConfig'

const totalTools = tools.length

// Map the seven existing data-categories onto the four brief-mandated columns:
//   ORGANISE = organize + edit + optimize
//   CONVERT  = convert-to-pdf + convert-from-pdf
//   SECURE   = security
//   READ     = ai (summarise/outline) + the existing OCR/extract tools
const COLUMNS = [
  {
    title: 'organise',
    slugs: [
      'merge-pdf', 'split-pdf', 'organize-pdf', 'rotate-pdf',
      'remove-pages', 'extract-pages', 'crop-pdf', 'add-page-numbers',
    ],
  },
  {
    title: 'convert',
    slugs: [
      'pdf-to-word', 'pdf-to-jpg', 'jpg-to-pdf', 'word-to-pdf',
      'html-to-pdf', 'excel-to-pdf', 'powerpoint-to-pdf', 'pdf-to-pdfa',
    ],
  },
  {
    title: 'secure',
    slugs: [
      'redact-pdf', 'sign-pdf', 'protect-pdf', 'unlock-pdf', 'add-watermark',
    ],
  },
  {
    title: 'read',
    slugs: [
      'ocr-pdf', 'ai-summarizer', 'compare-pdf', 'compress-pdf', 'optimize-pdf', 'repair-pdf',
    ],
  },
] as const

// Resolve each slug against the data so we get the real lowercase name.
const PRETTY: Record<string, string> = {
  'merge-pdf': 'bind',
  'split-pdf': 'split',
  'organize-pdf': 'reorder',
  'rotate-pdf': 'rotate',
  'remove-pages': 'delete pages',
  'extract-pages': 'extract pages',
  'crop-pdf': 'crop',
  'add-page-numbers': 'page numbers',
  'pdf-to-word': 'pdf → docx',
  'pdf-to-jpg': 'pdf → images',
  'jpg-to-pdf': 'images → pdf',
  'word-to-pdf': 'docx → pdf',
  'html-to-pdf': 'html → pdf',
  'excel-to-pdf': 'xlsx → pdf',
  'powerpoint-to-pdf': 'pptx → pdf',
  'pdf-to-pdfa': 'pdf → pdf/a',
  'redact-pdf': 'redact',
  'sign-pdf': 'sign',
  'protect-pdf': 'encrypt',
  'unlock-pdf': 'decrypt',
  'add-watermark': 'watermark',
  'ocr-pdf': 'ocr',
  'ai-summarizer': 'summarise',
  'compare-pdf': 'compare',
  'compress-pdf': 'compress',
  'optimize-pdf': 'optimise',
  'repair-pdf': 'repair',
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_CONFIG.name,
  url: SITE_CONFIG.origin,
  description: SITE_CONFIG.description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE_CONFIG.origin}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
}
---

<BaseLayout jsonLd={jsonLd} pageNum="1">
  <article class="home-column">
    <!-- Hero -->
    <header class="hero">
      <p class="hero-eyebrow smallcaps">no. {totalTools.toString().padStart(2, '0')} · documents craft</p>
      <h1 class="hero-h">PDF tools that never leave your desk.</h1>
      <p class="hero-sub">
        On-device. Open source. {totalTools} implements for the documents craft.
      </p>
    </header>

    <hr data-section="i" />

    <!-- Dropzone — pre-tool, framed as a single dashed leaf. -->
    <section class="drop">
      <a href="/tools/merge-pdf/" class="drop-frame" aria-label="Open the merge tool">
        <span class="drop-line">drop a leaf here, or pick an implement below</span>
        <span class="drop-meta mono">.pdf · max 100 MB · stays in your browser</span>
      </a>
    </section>

    <hr data-section="ii" />

    <!-- Four-column small-caps TOC. NOT a card grid. -->
    <section class="toc">
      {COLUMNS.map((col) => (
        <div class="toc-col">
          <h2 class="toc-h smallcaps">{col.title}</h2>
          <ul>
            {col.slugs
              .map((slug) => ({ slug, label: PRETTY[slug], tool: tools.find((t) => t.slug === slug) }))
              .filter((x) => x.tool)
              .map(({ slug, label }) => (
                <li>
                  <a href={`/tools/${slug}/`} class="toc-a">{label}</a>
                </li>
              ))}
          </ul>
        </div>
      ))}
    </section>

    <hr data-section="iii" />

    <!-- A short manuscript-tone manifesto. -->
    <section class="manifesto">
      <p>
        Every implement on this desk runs <em>in your browser</em>. Files you open are
        loaded into memory, worked on, and saved back — they are never sent to a server.
        There is no upload, no account required, and no telemetry on your documents.
      </p>
      <p>
        We use <code>pdf-lib</code> for editing, <code>pdfjs-dist</code> for rendering,
        <code>tesseract.js</code> for OCR, and a small set of friends. The whole thing is
        <a href={`https://github.com/chirag127/oriz-pdf-tools`}>open source under MIT</a>.
      </p>
    </section>

    <hr data-section="iv" />

    <!-- Recent writing — links into /blog/. -->
    <section class="recent">
      <h2 class="recent-h smallcaps">recent writing</h2>
      <ol class="recent-list">
        <li><a href="/blog/how-to-merge-pdf-files/">How to merge PDF files</a></li>
        <li><a href="/blog/best-free-pdf-tools-2026/">The 10 best free PDF tools, 2026</a></li>
        <li><a href="/blog/digital-signatures-pdf/">Digital signatures in PDFs</a></li>
        <li><a href="/blog/pdf-archive-format/">PDF/A: the archival format</a></li>
        <li><a href="/blog/pdf-redaction-vs-hiding/">Redaction vs covering: why the difference matters</a></li>
        <li><a href="/blog/" class="more">all writing →</a></li>
      </ol>
    </section>
  </article>
</BaseLayout>

<style>
  .home-column {
    max-width: var(--container-prose);
    margin-inline: auto;
    padding: 3rem clamp(1.25rem, 4vw, 2rem) 0;
    /* 8ch left gutter holds page numbers / marginalia. */
    padding-left: clamp(1.25rem, 8ch, 4rem);
  }

  /* Hero */
  .hero { padding-block: 1rem 2rem; }
  .hero-eyebrow {
    font-size: 13px;
    color: var(--margin);
    margin: 0 0 1rem;
  }
  .hero-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.25rem, 5vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 1rem;
  }
  .hero-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.0625rem, 2.4vw, 1.375rem);
    color: var(--margin);
    line-height: 1.45;
    margin: 0;
    max-width: 56ch;
  }

  /* Dropzone */
  .drop { padding-block: 1rem; }
  .drop-frame {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 2.75rem 1.5rem;
    border: 1px dashed var(--rule);
    text-align: center;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 120ms;
  }
  .drop-frame:hover {
    border-color: var(--ledger);
    color: var(--ledger);
  }
  .drop-line {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.0625rem;
    color: inherit;
  }
  .drop-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--margin);
    letter-spacing: 0.06em;
  }

  /* Four-column TOC */
  .toc {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem 1.5rem;
    padding-block: 1rem;
  }
  @media (min-width: 560px) { .toc { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 880px) { .toc { grid-template-columns: repeat(4, 1fr); } }

  .toc-h {
    font-size: 13px;
    color: var(--margin);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
    letter-spacing: 0.12em;
  }
  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc li { margin-bottom: 0.5rem; }
  .toc-a {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--ink);
    text-decoration: none;
  }
  .toc-a:hover {
    color: var(--ledger);
    text-decoration: underline;
    text-decoration-color: var(--ledger);
    text-underline-offset: 3px;
  }

  /* Manifesto */
  .manifesto {
    padding-block: 1rem;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--ink);
    max-width: 65ch;
  }
  .manifesto p { margin: 0 0 1rem; }
  .manifesto em { color: var(--margin); font-style: italic; }
  .manifesto code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    padding: 0 0.25em;
    background: var(--paper-2);
    border: 1px solid var(--rule);
  }
  .manifesto a {
    color: var(--ledger);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--ledger) 40%, transparent);
    text-underline-offset: 3px;
  }
  .manifesto a:hover { text-decoration-color: var(--ledger); }

  /* Recent writing */
  .recent { padding-block: 1rem 2rem; }
  .recent-h {
    font-size: 13px;
    color: var(--margin);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
    letter-spacing: 0.12em;
  }
  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: recent;
  }
  .recent-list li {
    position: relative;
    padding-left: 3ch;
    margin-bottom: 0.5rem;
    counter-increment: recent;
  }
  .recent-list li::before {
    content: counter(recent, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0.125em;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--margin);
    letter-spacing: 0.06em;
  }
  .recent-list a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .recent-list a:hover {
    color: var(--ledger);
    border-bottom-color: var(--ledger);
  }
  .recent-list .more {
    font-style: italic;
    color: var(--margin);
  }
</style>
