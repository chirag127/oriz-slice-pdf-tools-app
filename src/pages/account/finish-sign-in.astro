---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
	title="Finishing sign-in — PDF Tools"
	description="Completing email-link sign-in."
	canonical="/account/finish-sign-in"
>
	<section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-20 text-center">
		<h1 class="font-display text-2xl font-bold text-gray-900 mb-4">
			Finishing sign-in…
		</h1>
		<p class="text-gray-600">
			If you arrived here from an email link, hold tight.
			Once <code class="text-xs bg-gray-100 px-1.5 py-0.5 rounded">@chirag127/oriz-ui</code>
			is installed, this page will complete the magic-link handshake automatically.
		</p>
	</section>

	<meta slot="head" name="robots" content="noindex,nofollow" />
</BaseLayout>
