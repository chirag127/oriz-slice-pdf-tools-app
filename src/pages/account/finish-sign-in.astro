---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { FinishSignIn } from '@chirag127/oriz-ui'
---

<BaseLayout
  title="finishing sign-in — oriz / pdf-tools"
  description="Completing email-link sign-in."
  noindex={true}
  noRunningFoot={true}
>
  <section class="finish">
    <FinishSignIn client:only="react" />
  </section>
</BaseLayout>

<style>
  .finish {
    max-width: var(--container-prose);
    margin-inline: auto;
    padding-block: 5rem 4rem;
    text-align: center;
    font-family: var(--font-serif);
  }
</style>
