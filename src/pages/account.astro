---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { AccountPanel } from '@chirag127/oriz-ui'
---

<BaseLayout
  title="account — oriz / pdf-tools"
  description="Sign in to PDF Tools. One account works across every oriz site."
  noindex={true}
  pageNum="ii"
>
  <div class="page-head">
    <p class="eyebrow"><a href="/">tools</a> / account</p>
    <h1>Account.</h1>
    <p class="lede">
      One sign-in works across every oriz site. Bookmarks, reading history,
      and preferences follow you between sites.
    </p>
  </div>

  <hr data-section="i" />

  <section class="prose">
    <AccountPanel client:only="react" />
  </section>
</BaseLayout>
