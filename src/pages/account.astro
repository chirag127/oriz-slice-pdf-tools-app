---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
	title="Account — PDF Tools"
	description="Sign in to PDF Tools. One account works across every oriz site."
	canonical="/account"
>
	<section class="bg-gradient-to-br from-slate-50 to-blue-50/30 border-b border-gray-200/60">
		<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
			<p class="text-sm text-gray-500 mb-2">
				<a href="/" class="hover:text-gray-900">PDF Tools</a> / Account
			</p>
			<h1 class="font-display text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight mb-2">
				Account
			</h1>
			<p class="text-lg text-gray-600">
				One sign-in works across every oriz site. Your preferences and history follow you.
			</p>
		</div>
	</section>

	<section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
		<div class="card p-8 text-center">
			<p class="text-gray-700 mb-4">
				Account sign-in for the oriz family is wired through
				<a href="https://auth.oriz.in" class="text-blue-600 hover:underline">auth.oriz.in</a>.
			</p>
			<p class="text-sm text-gray-500">
				The interactive sign-in panel will be mounted here once the
				<code class="text-xs bg-gray-100 px-1.5 py-0.5 rounded">@chirag127/oriz-ui</code>
				package is installed.
			</p>
		</div>
	</section>

	<meta slot="head" name="robots" content="noindex,nofollow" />
</BaseLayout>
